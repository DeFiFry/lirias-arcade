# Node dependencies (regenerated by Launch-Arcade.bat / npm install)
frontend/node_modules/

# Local backup script - not part of the repo content itself
Lirias Arcade Backup.bat

# Game ROM files - folder structure is tracked, file contents are not.
# No ROMs are included in this repo. See INSTALL_GUIDE.pdf.
roms/*/*
!roms/*/.gitkeep

# Background music - folder is tracked, file contents are not (copyright).
# See INSTALL_GUIDE.pdf for how to add your own alice.mp3.
music/*
!music/.gitkeep

# PSX BIOS dumps - copyrighted console firmware, not included in this repo.
# bios/Mupen64plus/ is kept: it's an N64 ROM catalog + shader cache, not firmware.
/bios/*.bin
/bios/*.BIN
